{
  "name": "jang-heritage",
  "version": "0.1.0",
  "description": "Private archive for the Jang family letters and diaries.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run generate:types && pnpm run generate:importmap && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "pnpm run generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && pnpm run generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.730.0",
    "@payloadcms/db-postgres": "^3.59.0",
    "@payloadcms/drizzle": "^3.84.1",
    "@payloadcms/email-nodemailer": "^3.59.0",
    "@payloadcms/next": "^3.59.0",
    "@payloadcms/richtext-lexical": "^3.59.0",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "^3.59.0",
    "archiver": "^7.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.8.1",
    "next": "^16.2.3",
    "nodejieba": "^3.5.8",
    "payload": "^3.59.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.2",
    "strip-markdown": "^6.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.12",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "nodejieba"
    ]
  }
}
